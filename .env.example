NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your_key

# Server-only. Required only for trusted server jobs or admin workflows.
SUPABASE_SECRET_KEY=sb_secret_your_key

# Server-only. Required only when using the Financial Modeling Prep provider.
FMP_API_KEY=your_financial_modeling_prep_api_key

# Server-only. Required for the scheduled market-data refresh endpoint.
MARKET_DATA_REFRESH_SECRET=replace_with_a_long_random_secret
